# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=akademik_db
DATABASE_URL="mysql://root:your_password@localhost:3306/akademik_db"
DB_CONNECTION_LIMIT=50
DB_QUEUE_LIMIT=500
DB_LIST_QUERY_LIMIT=1000
DB_MAX_LIST_QUERY_LIMIT=5000
DB_CONNECT_TIMEOUT=10000

# Auth token configuration
JWT_SECRET=replace-with-a-long-random-secret
# JWT_ISSUER=watum

# Environment
NODE_ENV=development
AUTO_APPLY_MIGRATIONS=true

# Optional benchmark / audit script credentials
# WATUM_ADMIN_EMAIL=admin@watum.local
# WATUM_ADMIN_PASSWORD=replace-with-admin-password

# Production / reverse proxy
# ORIGIN=https://your-domain.example.com
# COOLIFY_FQDN=your-domain.example.com
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# PORT_HEADER=x-forwarded-port
